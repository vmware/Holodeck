# Internal Holodeck nested environment FQDNs (not resolvable externally)
.*\.site-a\.vcf\.lab
.*\.site-b\.vcf\.lab

# Internal VCF lab service URLs (not resolvable externally)
https?://[^/]*\.vcf\.lab.*

# Placeholder hostnames used in documentation examples
https?://holorouter-ip.*

# Broadcom community site frequently returns 500 to automated requests
https://community\.broadcom\.com/.*

# Placeholder IP used in offline depot instructions
http://*oda-ip*/

# LinkedIn blocks all automated crawlers with 999 status
https://www\.linkedin\.com/.*
